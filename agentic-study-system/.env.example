# Agentic Study System — secrets & endpoints
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real keys.

# --- API engine (the "Heavy Lifter"): set at least one ---
# Used by Phase 1 ingestion and Phase 3 Socratic Dismantler.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional. Fill this only when using a third-party OpenAI-compatible API.
# Example: https://your-provider.example/v1
OPENAI_BASE_URL=

# Which API provider the "api" engine resolves to: anthropic | openai | vllm
API_PROVIDER=anthropic

# --- Self-hosted "Heavy Lifter": vLLM (OpenAI-compatible, e.g. gpt-oss on tailab) ---
# Only used when API_PROVIDER=vllm. Reach the remote container via an SSH tunnel
# (scripts/tailab_tunnel.sh maps tailab host:8006 -> localhost:8006). gpt-oss is
# text-only, so Phase 1 slide vision is dropped under this provider.
VLLM_BASE_URL=http://localhost:8006/v1
VLLM_API_KEY=

# --- Local engine (the "Fast Chatter"): Ollama ---
# Default host is fine if Ollama runs locally.
OLLAMA_HOST=http://localhost:11434

# --- Optional RAG service: LightRAG Server ---
# If not configured or unavailable, the app falls back to local lexical RAG over
# generated notes and PDFs. Recommended for production/demo:
#   LIGHTRAG_BASE_URL=http://127.0.0.1:9621
LIGHTRAG_BASE_URL=
LIGHTRAG_API_KEY=
LIGHTRAG_DEFAULT_MODE=mix

# LightRAG Server -> LLM provider
LIGHTRAG_LLM_API_KEY=
LIGHTRAG_LLM_BASE_URL=
LIGHTRAG_LLM_MODEL=gpt-5.4-mini
