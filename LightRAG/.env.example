HOST=127.0.0.1
PORT=9621

# LLM: OpenAI-compatible
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1   # 或第三方兼容端点，如 https://yunwu.ai/v1
LLM_BINDING_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o

# Embedding: local Ollama（需先 ollama pull nomic-embed-text）
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768

# Storage dirs（相对于启动命令所在目录）
WORKING_DIR=./rag_storage
INPUT_DIR=./inputs
